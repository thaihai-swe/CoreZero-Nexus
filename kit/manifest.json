{
  "name": "harness-kit",
  "version": "0.0.1",
  "description": "Spec-anchored AI software delivery framework with durable memory tiers and a mechanical verification gate.",
  "homepage": "https://github.com/thaihai-swe/CoreZero-Nexus",
  "files": {
    "overwrite": [
      "skills/README.md",
      "skills/_shared/**",
      "skills/context-compact/**",
