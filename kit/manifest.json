  "templateMap": {},
    "directories": [
      "skills",
      "memories/repo",
      "memories/domain",
      "artifacts/features",
      "docs",
      "docs/project",
      "docs/policies",
      "docs/generated",
      "docs/rules",
      "scripts"
    ]
}
