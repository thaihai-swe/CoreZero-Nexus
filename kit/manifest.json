      "skills/spec-implement/**",
      "skills/spec-plan/**",
      "skills/spec-requirements/**",
      "skills/spec-research/**",
      "skills/starter-init/**",
      "skills/code-review/**",
      "skills/ponytail/**",
      "skills/technical-docs/**",
      "skills/codebase-documenter/**",
      "skills/visualize/**",
      "scripts/install.sh",
      "scripts/harness/**",
      "scripts/generate-dashboard.py",
      "scripts/context-loader.py",
      "scripts/harness/gate-runner.local.example.sh",
      "docs/rules/security.md",
      "docs/rules/ponytail.md",
