      "memories/repo/adr-log.md",
      "docs/project/architecture.md",
      "docs/project/product-sense.md",
      "docs/project/project-constraints.md",
      "docs/project/glossary.md",
      "docs/project/tech-stack.md",
      "docs/project/code-map.md",
      "docs/project/agent-capabilities.md",
      "docs/generated/dashboard.html",
      "artifacts/features/README.md",
      "memories/domain/README.md",
      "memories/domain/example/glossary.md",
      "memories/domain/example/patterns.md",
      "memories/domain/example/anti-patterns.md",
      "memories/domain/example/boundaries.md",
      "skills/context-memory/references/project-knowledge-base-template.md"
    ],
    "crossTreeOverwrite": [],
    "preserve": [
