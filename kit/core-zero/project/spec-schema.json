{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["feature", "slug", "profile", "status"],
  "properties": {
    "feature": {
      "type": "string",
      "description": "Human-readable feature name"
    },
    "slug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Machine-readable feature identifier"
    },
    "profile": {
      "type": "string",
      "enum": ["Tiny", "Standard", "Complex"],
      "description": "Delivery profile"
    },
    "status": {
      "type": "string",
      "enum": ["Draft", "Review", "Approved", "Amended", "Stale"],
      "description": "Spec status"
    },
    "req_ids": {
      "type": "array",
      "items": {"type": "string", "pattern": "^REQ-\\d+$"},
      "description": "Requirement IDs referenced in this spec"
    },
    "ac_ids": {
      "type": "array",
      "items": {"type": "string", "pattern": "^AC-\\d+$"},
      "description": "Acceptance criteria IDs referenced in this spec"
    }
  },
  "additionalProperties": true
}
