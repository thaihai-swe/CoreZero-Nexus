flowchart TD
    %% CoreZero Gate Chain — each layer guards the layer below
    %% READ TOP-DOWN for *why* a line of code exists
    %% READ BOTTOM-UP for *how far* a single change can propagate

    ANNO_TOP["READ TOP-DOWN — WHY this line of code exists"]:::anno

    %% ── Layer 1: Constitution ──
    POL["<b>Constitution</b><br/>core-policies.md · adr-log.md · core-zero/rules/<br/><em>principles · tech stack · quality bars · security</em>"]:::pol
    ARW1:::arrow

    %% ── Layer 2: Spec ──
    SPEC["<b>Spec — What &amp; Why</b><br/>artifacts/features/&lt;slug&gt;/spec.md<br/><em>requirements · acceptance criteria · invariants · non-goals</em>"]:::spec
    ARW2:::arrow

    %% ── Layer 3: Plan ──
    PLAN["<b>Plan — How</b><br/>plan.md + tasks.md<br/><em>technical design · task breakdown · ID-to-AC traceability</em>"]:::plan
    ARW3:::arrow

    %% ── Layer 4: Implementation ──
    IMPL["<b>Implementation</b><br/>src/ · tests/<br/><em>code · tests · proof evidence · baseline before edit</em>"]:::impl
    ARW4:::arrow

    %% ── Layer 5: Verification ──
    VER["<b>Verification</b><br/>review.md + testing-scenarios.md<br/><em>mechanical gates · alignment audit · security lens · verdict</em>"]:::ver
    ARW5:::arrow

    %% ── Layer 6: Closeout ──
    CLOSE["<b>Closeout</b><br/>session-extracts.md · core-zero/memories/repo/<br/><em>handoff · knowledge promotion · durable record · next session starts primed</em>"]:::close

    %% Arrows down (gating)
    POL --> ARW1 --> SPEC
    SPEC --> ARW2 --> PLAN
    PLAN --> ARW3 --> IMPL
    IMPL --> ARW4 --> VER
    VER --> ARW5 --> CLOSE

    %% Right-side gate labels
    POL -.->|gates ↓| SPEC
    SPEC -.->|gates ↓| PLAN
    PLAN -.->|gates ↓| IMPL
    IMPL -.->|gates ↓| VER
    VER -.->|gates ↓| CLOSE

    ANNO_BOT["READ BOTTOM-UP — HOW FAR a single change propagates"]:::anno

    %% ── Styles ──
    classDef pol fill:#dc2626,stroke:#b91c1c,color:#fff
    classDef spec fill:#f59e0b,stroke:#d97706,color:#fff
    classDef plan fill:#0284c7,stroke:#0369a1,color:#fff
    classDef impl fill:#6366f1,stroke:#4f46e5,color:#fff
    classDef ver fill:#10b981,stroke:#059669,color:#fff
    classDef close fill:#0891b2,stroke:#0e7490,color:#fff
    classDef arrow fill:none,stroke:none
    classDef anno fill:none,stroke:none,color:#64748b
