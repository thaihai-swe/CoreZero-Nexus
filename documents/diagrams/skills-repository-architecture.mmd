flowchart TB
    subgraph BC["Bootstrap &amp; Context"]
        START["starter-init"]
        SESS["context-session"]
        STATUS["context-status"]
        MEMORY["context-memory"]
        COMPACT["context-compact"]
    end

    subgraph SD["Spec-Driven Delivery"]
        RESEARCH["spec-research"]
        SPEC["spec-requirements"]
        ADR["spec-adr"]
        PLAN["spec-plan"]
        IMPL["spec-implement"]
    end

    subgraph QA["Quality &amp; Maintenance"]
        VERIFY["harness-verify"]
        REVIEW["code-review"]
        PONY["ponytail"]
        MAINTAIN["harness-maintain"]
    end

    subgraph DOC["Documentation &amp; Visualization"]
        VIS["visualize"]
        TECDOC["technical-docs"]
        CODE["codebase-documenter"]
    end

    START --> STATUS
    STATUS --> MEMORY
    MEMORY --> RESEARCH
    RESEARCH --> SPEC
    SPEC --> VIS
    SPEC --> ADR
    SPEC --> PLAN
    PLAN --> IMPL
    IMPL --> VERIFY
    VERIFY --> REVIEW
    REVIEW --> PONY
    PONY --> SESS
    SESS --> COMPACT

    VERIFY -. harness failure .-> MAINTAIN
    MAINTAIN -. durable improvement .-> MEMORY

    RESEARCH -. repo evidence .-> TECDOC
    MEMORY -. terminology and rules .-> CODE

    classDef primary fill:#ffffff,stroke:#10a37f,color:#0d0d0d,stroke-width:1.5px;
    classDef neutral fill:#ffffff,stroke:#d0d7de,color:#0d0d0d,stroke-width:1.2px;
    class START,MEMORY,SPEC,PLAN primary;
    class SESS,STATUS,COMPACT,RESEARCH,VIS,ADR,IMPL,VERIFY,REVIEW,PONY,TECDOC,CODE,MAINTAIN neutral;
