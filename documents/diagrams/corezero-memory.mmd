flowchart TD
    %% 3-Tier Memory Architecture (Instruction / Auto / Extracted)

    subgraph INSTR["Instruction Tier — Human-Curated, Durable"]
        CONST[core-policies.md<br/>Normative rules, security policy, thresholds]
        CONFIG[harness-config.md<br/>Adopter identity, commands, lifecycle defaults]
        PKB[project-knowledge-base.md<br/>Durable patterns, watchouts, continuity facts]
        ADR[adr-log.md<br/>Architectural decision index]
        HEUR[learned-heuristics.md<br/>Evidence-backed execution instincts]
    end

    subgraph AUTO["Auto Tier — Failure-Driven, Append-Only"]
        OBS[harness-telemetry.md<br/>Harness / Model / Spec failures]
    end

    subgraph EXTR["Extracted Tier — Per-Feature Candidates"]
        EXT[session-extracts.md<br/>Candidate lessons from each feature]
    end

    subgraph ROUTER["Memory Router"]
        IDX[MASTER_INDEX.md<br/>Always-loaded routing index]
    end

    subgraph PACKS["Domain Packs — Adopter-Owned"]
        DPACK[core-zero/memories/domain/<br/>glossary + patterns + anti-patterns + boundaries]
    end

    %% Routing from MASTER_INDEX.md trigger groups
    IDX -->|Always| CONST
    IDX -->|By Intent: Config| CONFIG
    IDX -->|By Intent: Knowledge| PKB
    IDX -->|By Intent: Knowledge| ADR
    IDX -->|By Intent: Learned| HEUR
    IDX -->|By Domain Packs| DPACK
    IDX -->|By Debug| OBS
    IDX -->|By Debug| EXT

    %% Promotion flow (extracted -> instruction)
    EXT -.->|context-memory<br/>Extraction Triage| CONST
    EXT -.->|context-memory<br/>Extraction Triage| PKB
    EXT -.->|context-memory<br/>Extraction Triage| HEUR
    OBS -.->|3+ recurrences →<br/>propose promotion| HEUR

    %% Writers
    AIDV[harness-verify<br/>Post-Ship Sync] -->|writes record| EXT
    AIHN[harness-maintain<br/>Improve Mode] -->|appends| OBS
    AIDS[context-session END] -->|appends candidates| EXT
    AIADR[spec-adr] -->|writes decision| ADR

    classDef instr fill:#10b981,stroke:#047857,color:#fff
    classDef auto fill:#f59e0b,stroke:#b45309,color:#fff
    classDef extr fill:#8b5cf6,stroke:#6d28d9,color:#fff
    classDef router fill:#3b82f6,stroke:#1d4ed8,color:#fff
    classDef writer fill:#fff,stroke:#0d0d0d,color:#0d0d0d
    classDef packs fill:#eef2ff,stroke:#c7d2fe,color:#3730a3

    class CONST,CONFIG,PKB,ADR,HEUR instr
    class OBS auto
    class EXT extr
    class IDX router
    class DPACK packs
    class AIDV,AIHN,AIDS,AIADR writer
