flowchart TD
    %% Verification Gate — split modes, sole completion authority

    START([Implementation complete]) --> PHASE["1 - Initialization<br/>status.md = Verifying"]:::step
    PHASE --> GATE["2 - Mechanical Gate Audit<br/>Run plan gate commands"]:::step

    GATE --> GPASS{Gate passes?}:::decision
    GPASS -- No --> FAIL["Verdict Fail<br/>Reopen tasks & write review.md"]:::fail
    FAIL --> STOPF([Return to implement]):::fail

    GPASS -- Yes --> CLEAN["3 - Clean-State Check<br/>No uncommitted changes"]:::step
    CLEAN --> ALIGN["4 - Alignment Audit<br/>REQ/AC mapping to tasks"]:::step
    ALIGN --> SEC["5 - Security Lens<br/>Audit vs core-policies.md"]:::step
    SEC --> HELPERS["6 - Helper Skills<br/>Code Review / Harness Maintain"]:::step

    HELPERS --> FALLOW{Fallow Cleanup?}:::decision
    FALLOW -- Yes --> CLEANUP["7 - Optional Fallow Pass<br/>Cleanup targets & re-run proof"]:::step
    FALLOW -- No --> WRITE_REV

    CLEANUP --> WRITE_REV["8 - Write Review<br/>Write findings to review.md"]:::step
    WRITE_REV --> SCEN["9 - Scenarios<br/>Draft testing-scenarios.md"]:::step

    SCEN --> VERDICT{10 - Verdict}:::decision
    VERDICT -- Fail --> FAIL
    VERDICT -- Pass / Pass with Debt --> SYNC["11 - Post-Ship Sync<br/>Post-Ship Sync memory sweep"]:::pass

    SYNC --> DONE([status = Done]):::terminal

    classDef terminal fill:#0d0d0d,stroke:#0d0d0d,color:#fff
    classDef decision fill:#fff7ed,stroke:#f59e0b,color:#0d0d0d
    classDef step fill:#fff,stroke:#d0d7de,color:#0d0d0d
    classDef fail fill:#fcf3f3,stroke:#f2c4c4,color:#c62828
    classDef pass fill:#ebf5ed,stroke:#c3e0c5,color:#2d7d32

    class START,DONE terminal
    class GPASS,FALLOW,VERDICT decision
    class PHASE,GATE,CLEAN,ALIGN,TRACE,SEC,HELPERS,CLEANUP,WRITE_REV,SCEN step
    class FAIL,STOPF fail
    class SYNC pass
