flowchart TD
    %% Full End-to-End Flow — current skill set, required vs optional

    START([Request]) --> EXIST{Is it an existing repo?}
    EXIST -- yes --> INIT
    EXIST -- no --> INIT
    INIT["starter-init<br/>Phase A: archaeology (brownfield only)<br/>Phase B: bootstrap (all repos)"]

    %% Setup phase
    INIT --> SESSION_START[context-session START<br/>Open Feature Boundary]
    SESSION_START --> HARNESS{First time or<br/>structural issue?}
    HARNESS -. assess maturity .-> ASSESS["harness-maintain<br/>(Assess Mode)"]
    ASSESS -.-> NEEDRES
    HARNESS --> NEEDRES{Behavior unknown<br/>or brownfield?}

    %% Investigation phase
    NEEDRES -. yes .-> RES["spec-research<br/>(analysis.md)"]
    RES --> SPEC
    NEEDRES --> SPEC["spec-requirements<br/>(grilling waves + spec.md)"]

    %% Design phase
    SPEC --> NEEDVIS{Complex flow<br/>worth a diagram?}
    NEEDVIS -. yes .-> VIS["visualize<br/>(diagram.svg or diagram.mmd)"]
    VIS --> NEEDADR
    NEEDVIS --> NEEDADR{Architectural<br/>decision?}
    NEEDADR -. yes .-> ADR["spec-adr<br/>(adr-NNN.md)"]
    ADR --> PLAN
    NEEDADR --> PLAN["spec-plan<br/>(plan.md + tasks.md + design.md)"]

    %% Execution phase
    PLAN --> IMPL["spec-implement<br/>(one task at a time + proof)"]
    IMPL --> VERIFY["harness-verify<br/>(review.md + testing-scenarios.md)"]

    VERIFY -- gate fail --> IMPL
    VERIFY -- spec drift --> SPEC
    VERIFY -- pass --> SYNC[Post-Ship Sync<br/>context-memory sweep]

    %% Learning loop
    VERIFY -. harness lesson .-> IMPROVE["harness-maintain<br/>(Improve Mode)"]
    IMPROVE -. durable fix .-> INIT

    %% Documentation and Review phase (optional utility skills)
    SYNC --> NEEDDOCS{Refresh docs<br/>or review PR?}
    NEEDDOCS -. technical docs changed .-> TECHDOC["technical-docs<br/>(api, flow, or both modes)"]
    NEEDDOCS -. architecture changed .-> CODEDOC["codebase-documenter<br/>(docs/ root README/ARCHITECTURE)"]
    NEEDDOCS -. PR ready .-> CODEREV["code-review<br/>(review.md)"]
    TECHDOC -.-> ENDS
    CODEDOC -.-> ENDS
    CODEREV -.-> ENDS

    NEEDDOCS --> ENDS["context-session END<br/>(handoff.md + session-extracts.md)"]
    ENDS --> DONE([Shipped + KB compounded])

    %% Legend
    LEGEND["Solid = required path<br/>Dashed = optional / conditional"]:::legend

    classDef terminal fill:#0d0d0d,stroke:#0d0d0d,color:#fff
    classDef core fill:#fff,stroke:#10a37f,color:#0d0d0d,stroke-width:1.6px
    classDef optional fill:#fff,stroke:#94a3b8,color:#475569,stroke-dasharray:4 3
    classDef gate fill:#3b82f6,stroke:#1d4ed8,color:#fff
    classDef decision fill:#fff7ed,stroke:#f59e0b,color:#0d0d0d
    classDef legend fill:#f7f7f5,stroke:#e0e0e0,color:#111

    class START,DONE terminal
    class INIT,SESSION_START,SPEC,PLAN,IMPL,ENDS core
    class ASSESS,RES,VIS,ADR,IMPROVE,TECHDOC,CODEDOC,CODEREV optional
    class VERIFY,SYNC gate
    class HARNESS,EXIST,NEEDRES,NEEDVIS,NEEDADR,NEEDDOCS decision
    class LEGEND legend
